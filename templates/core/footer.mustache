            </div>

            <div class="col-12 col-md-5 col-lg-4">
                <p class="alfa-footer__partner-title mb-3">Parceria</p>
                <img src="{{config.wwwroot}}/theme/alfa/pix/petrobras-white.svg" alt="Logo da Petrobras" class="alfa-footer__partner-logo alfa-footer__partner-logo--petrobras">
            </div>
        </div>

        <hr class="alfa-footer__divider alfa-footer__divider--bottom">

        <p class="alfa-footer__legal text-center mb-0">INSTITUTO DE EDUCA&Ccedil;&Atilde;O E DIREITOS HUMANOS PAULO FREIRE | CNPJ 04.950.603/0001-05</p>
    </div>
