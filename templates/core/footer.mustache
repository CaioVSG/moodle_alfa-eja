            <div class="col-12 col-lg-4 text-center text-lg-left mb-4 mb-lg-0">
                <img src="{{config.wwwroot}}/theme/alfa/pix/logo_rodape_alfa_eja_brasil.svg" alt="Logo do sistema" class="alfa-footer__brand">
                <p class="alfa-footer__tagline mb-0">{{ get_config('theme_alfa', 'footertext') }}</p>
            </div>

            <div class="col-6 col-lg-3">
                <ul class="list-unstyled alfa-footer__menu mb-0">
                    <li><a href="youtube.com" class="text-reset text-decoration-none">In&iacute;cio</a></li>
                    <li><a href="youtube.com" class="text-reset text-decoration-none">Blog</a></li>
                    <li><a href="youtube.com" class="text-reset text-decoration-none">Podcast</a></li>
                    <li><a href="youtube.com" class="text-reset text-decoration-none">Materiais</a></li>
                </ul>
            </div>

            <div class="col-6 col-lg-3">
                <ul class="list-unstyled alfa-footer__menu mb-0">
                    <li><a href="youtube.com" class="text-reset text-decoration-none">O projeto ALFA-EJA Brasil</a></li>
                    <li><a href="youtube.com" class="text-reset text-decoration-none">Pol&iacute;tica de privacidade</a></li>
                    <li><a href="youtube.com" class="text-reset text-decoration-none">Termos de uso</a></li>
                    <li><a href="youtube.com" class="text-reset text-decoration-none">Contato</a></li>
                </ul>
